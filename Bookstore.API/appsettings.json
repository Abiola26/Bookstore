{
  "ConnectionStrings": {
    "DefaultConnection": "Host=YOUR_DB_HOST;Port=5432;Database=bookstoredb;Username=postgres;Password=YOUR_DATABASE_PASSWORD;SSL Mode=Disable"
  },
  "JWT": {
    "Key": "YOUR_JWT_SECRET_KEY_HERE",
    "Issuer": "BookstoreAPI",
    "Audience": "BookstoreClients",
    "ExpirationMinutes": 1440
  },
  "Email": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "EnableSsl": true,
    "Username": "YOUR_EMAIL_USERNAME",
    "Password": "YOUR_EMAIL_APP_PASSWORD",
    "FromAddress": "noreply@example.com",
    "FromName": "Bookstore",
    "ConfirmationTokenExpiryHours": 24,
    "ConfirmationUrlOrigin": "http://localhost:3000",
    "ApiBaseUrl": "https://localhost:7021"
  },
  "Paystack": {
    "SecretKey": "YOUR_PAYSTACK_SECRET_KEY",
    "PublicKey": "YOUR_PAYSTACK_PUBLIC_KEY"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}